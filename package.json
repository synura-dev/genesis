{
  "name": "@synura/genesis",
  "version": "0.0.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prebuild": "rimraf dist",
    "prepare": "bun run build",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "rimraf": "^6.1.3",
    "tsup": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "eventemitter3": "^5.0.4"
  }
}